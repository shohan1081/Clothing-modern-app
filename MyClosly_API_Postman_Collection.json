				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.tokens) {",
									"    pm.collectionVariables.set(\"accessToken\", jsonData.data.tokens.access);",
									"    pm.collectionVariables.set(\"refreshToken\", jsonData.data.tokens.refresh);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/login/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"login",
								""
							]
						},
						"description": "Authenticates user credentials and returns JWT access and refresh tokens. Saves tokens in collection variables."
					},
					"response": []
				},
