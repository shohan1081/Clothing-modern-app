		{
			"name": "Token Management",
			"item": [
				{
					"name": "Token Refresh",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    pm.collectionVariables.set(\"accessToken\", jsonData.data.access);",
									"    if (jsonData.data.refresh) {",
									"        pm.collectionVariables.set(\"refreshToken\", jsonData.data.refresh);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/token/refresh/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"token",
								"refresh",
								""
							]
						},
						"description": "Refreshes an expired access token using the valid refresh token."
					},
					"response": []
				},
