						"body": {
							"mode": "raw",
							"raw": "{\n    \"refresh\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/logout/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"logout",
								""
							]
						},
						"description": "Logs out the authenticated user by blacklisting the provided refresh token."
					},
					"response": []
				}
